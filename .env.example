# FireAnt
FIREANT_TOKEN=your_fireant_token_here

# Supabase (cùng project với Electron app)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Email (Resend)
RESEND_API_KEY=your_resend_key
ALERT_FROM_EMAIL=alerts@yourdomain.com

# App
PORT=8000
CORS_ORIGINS=http://localhost:5173

# DNSE OpenAPI (market data realtime + lịch sử) — đăng ký tại developers.dnse.com.vn
# Để trống = tắt DNSE, dùng vnstock như cũ. Có key = bật streaming cho Shark Action.
DNSE_API_KEY=
DNSE_API_SECRET=
